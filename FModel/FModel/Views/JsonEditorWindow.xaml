<adonisControls:AdonisWindow x:Class="FModel.Views.JsonEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
        xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="JSON Editor"
        Width="1000" Height="700"
        MinWidth="600" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        IconVisibility="Collapsed"
        Loaded="OnLoaded"
        Closing="OnClosing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Path bar ───────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                BorderThickness="0,0,0,1" Padding="10,6">
            <TextBlock x:Name="TxtPath"
                       FontFamily="Consolas" FontSize="11"
                       Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
        </Border>

        <!-- ── JSON editor ────────────────────────────────────────────── -->
        <avalonEdit:TextEditor x:Name="Editor"
                               Grid.Row="1"
                               FontFamily="Consolas"
                               FontSize="12"
                               ShowLineNumbers="True"
                               WordWrap="False"
                               Background="{DynamicResource {x:Static adonisUi:Brushes.Layer0BackgroundBrush}}"
                               Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}" />

        <!-- ── Action bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                BorderThickness="0,1,0,0" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnApply"
                        Content="Apply to .uasset"
                        Padding="12,4" FontWeight="SemiBold"
                        Click="BtnApply_Click"/>
                <TextBlock x:Name="TxtStatus"
                           Text="Edit JSON then click Apply."
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}"
                           Margin="14,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</adonisControls:AdonisWindow>
