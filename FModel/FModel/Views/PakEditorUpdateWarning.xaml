<adonisControls:AdonisWindow x:Class="FModel.Views.PakEditorUpdateWarning"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
                             xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
                             xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
                             Title="PakEditor — Update Warning"
                             WindowStartupLocation="CenterScreen"
                             ResizeMode="NoResize"
                             IconVisibility="Collapsed"
                             SizeToContent="Height"
                             Width="480">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Warning message -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,20,20,12">
            <TextBlock Text="⚠" FontSize="32" Foreground="#E8A838"
                       VerticalAlignment="Top" Margin="0,0,14,0" />
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap"
                           Text="A new FModel update is available, but you are running PakEditor — a fork with extra features." />
                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                           Text="Updating will replace the JSON editor, asset editor, and curve graph with the standard FModel build. Those features will be lost." />
            </StackPanel>
        </StackPanel>

        <!-- "Do not ask again" checkbox -->
        <CheckBox x:Name="DoNotAskCheckBox"
                  Grid.Row="1"
                  Content="Do not ask for updates again"
                  Margin="20,0,20,16"
                  HorizontalAlignment="Left" />

        <!-- Footer buttons -->
        <Border Grid.Row="2"
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                adonisExtensions:LayerExtension.IncreaseLayer="True">
            <Grid Margin="16,10,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" MinWidth="110" Content="Yes, update"
                        Click="OnYes" />
                <Button Grid.Column="3" MinWidth="140" Content="No, keep PakEditor"
                        IsCancel="True" Click="OnNo" />
            </Grid>
        </Border>
    </Grid>
</adonisControls:AdonisWindow>
