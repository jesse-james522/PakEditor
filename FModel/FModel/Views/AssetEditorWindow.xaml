<adonisControls:AdonisWindow x:Class="FModel.Views.AssetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
        xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
        xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
        Title="Asset Editor"
        Width="1200" Height="680"
        MinWidth="800" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        IconVisibility="Collapsed"
        Loaded="OnLoaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Path bar ───────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                BorderThickness="0,0,0,1" Padding="10,6">
            <Grid>
                <TextBlock x:Name="TxtPath"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtLoading" Text="Loading…"
                           FontSize="11"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Column headers ─────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                BorderThickness="0,0,0,1" Padding="22,3,8,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Text="Name"        FontFamily="Consolas" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}"/>
                <TextBlock Grid.Column="1"  Text="Type"        FontFamily="Consolas" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}" Padding="4,0,0,0"/>
                <TextBlock Grid.Column="2"  Text="Variant"     FontFamily="Consolas" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}" Padding="4,0,0,0"/>
                <TextBlock Grid.Column="3"  Text="Value 1"     FontFamily="Consolas" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}" Padding="4,0,0,0"/>
                <TextBlock Grid.Column="4"  Text="Value 2"     FontFamily="Consolas" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}" Padding="4,0,0,0"/>
                <TextBlock Grid.Column="5"  Text="Value 3"     FontFamily="Consolas" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}" Padding="4,0,0,0"/>
                <TextBlock Grid.Column="6"  Text="Value 4"     FontFamily="Consolas" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}" Padding="4,0,0,0"/>
                <TextBlock Grid.Column="7"  Text="Idx"         FontFamily="Consolas" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}" Padding="4,0,0,0"/>
                <TextBlock Grid.Column="8"  Text="Offset"      FontFamily="Consolas" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}" Padding="4,0,0,0"/>
                <TextBlock Grid.Column="9"  Text="Zero"        FontFamily="Consolas" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}" Padding="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── Property tree ──────────────────────────────────────────── -->
        <TreeView x:Name="PropTree"
                  Grid.Row="2"
                  FontFamily="Consolas" FontSize="11"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  BorderThickness="0"
                  Background="{DynamicResource {x:Static adonisUi:Brushes.Layer0BackgroundBrush}}"
                  ContextMenuOpening="PropTree_ContextMenuOpening">

            <TreeView.ContextMenu>
                <ContextMenu x:Name="PropContextMenu">
                    <MenuItem x:Name="MenuAddElement"       Header="Add element"       Click="AddArrayElement_Click"/>
                    <MenuItem x:Name="MenuRemoveElement"    Header="Remove element"    Click="RemoveArrayElement_Click"/>
                    <MenuItem x:Name="MenuDuplicateElement" Header="Duplicate element" Click="DuplicateArrayElement_Click"/>
                </ContextMenu>
            </TreeView.ContextMenu>

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                    <Setter Property="IsExpanded"  Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="Foreground"  Value="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"/>
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="Padding"     Value="2,1"/>
                </Style>
            </TreeView.ItemContainerStyle>

            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Name -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Name}"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                                   Padding="0,1" TextTrimming="CharacterEllipsis"/>

                        <!-- Type -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding TypeName}"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}"
                                   Padding="4,1,0,1" TextTrimming="CharacterEllipsis"/>

                        <!-- Variant -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Variant}"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}"
                                   Padding="4,1,0,1" TextTrimming="CharacterEllipsis"/>

                        <!-- Value 1 -->
                        <TextBox Grid.Column="3"
                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 IsReadOnly="{Binding IsReadOnly}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                                 CaretBrush="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                                 Padding="4,1,0,1"
                                 VerticalAlignment="Center"
                                 PreviewMouseLeftButtonDown="PropValue_PreviewMouseDown"
                                 GotKeyboardFocus="PropValue_GotFocus"/>

                        <!-- Value 2 -->
                        <TextBox Grid.Column="4"
                                 Text="{Binding V2, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 IsReadOnly="{Binding IsReadOnly2}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                                 CaretBrush="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                                 Padding="4,1,0,1"
                                 VerticalAlignment="Center"
                                 PreviewMouseLeftButtonDown="PropValue_PreviewMouseDown"
                                 GotKeyboardFocus="PropValue_GotFocus"/>

                        <!-- Value 3 -->
                        <TextBox Grid.Column="5"
                                 Text="{Binding V3, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 IsReadOnly="{Binding IsReadOnly3}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                                 CaretBrush="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                                 Padding="4,1,0,1"
                                 VerticalAlignment="Center"
                                 PreviewMouseLeftButtonDown="PropValue_PreviewMouseDown"
                                 GotKeyboardFocus="PropValue_GotFocus"/>

                        <!-- Value 4 -->
                        <TextBox Grid.Column="6"
                                 Text="{Binding V4, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 IsReadOnly="{Binding IsReadOnly4}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                                 CaretBrush="{DynamicResource {x:Static adonisUi:Brushes.ForegroundBrush}}"
                                 Padding="4,1,0,1"
                                 VerticalAlignment="Center"
                                 PreviewMouseLeftButtonDown="PropValue_PreviewMouseDown"
                                 GotKeyboardFocus="PropValue_GotFocus"/>

                        <!-- Array Index (read-only) -->
                        <TextBlock Grid.Column="7"
                                   Text="{Binding ArrayIndexDisplay}"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}"
                                   Padding="4,1,0,1"/>

                        <!-- Offset (read-only) -->
                        <TextBlock Grid.Column="8"
                                   Text="{Binding OffsetDisplay}"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}"
                                   Padding="4,1,0,1" TextTrimming="CharacterEllipsis"/>

                        <!-- Is Zero (read-only) -->
                        <TextBlock Grid.Column="9"
                                   Text="{Binding IsZero}"
                                   Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}"
                                   Padding="4,1,0,1"/>
                    </Grid>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- ── Save bar ───────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BackgroundBrush}}"
                BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}"
                BorderThickness="0,1,0,0" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnSave"
                        Content="Save Changes"
                        Padding="12,4" FontWeight="SemiBold"
                        IsEnabled="False"
                        Click="BtnSave_Click"/>
                <Button x:Name="BtnOpenExternal"
                        Content="Open in UAssetGUI"
                        Padding="12,4" Margin="8,0,0,0"
                        Click="BtnOpenExternal_Click"/>
                <TextBlock x:Name="TxtStatus"
                           Text="Loading…"
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource {x:Static adonisUi:Brushes.DisabledForegroundBrush}}"
                           Margin="14,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</adonisControls:AdonisWindow>
