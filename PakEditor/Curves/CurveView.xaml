<UserControl x:Class="PakEditor.Curves.CurveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">
    <UserControl.Resources>

        <!-- Tracker tooltip — styled to match FModel's dark theme.
             TrackerControl as root is required: it handles its own positioning
             on OxyPlot's overlay canvas and draws the crosshair lines. -->
        <ControlTemplate x:Key="FModelTrackerTemplate">
            <oxy:TrackerControl Position="{Binding Position}"
                                LineExtents="{Binding PlotModel.PlotArea}"
                                Background="#EE1E1E2E"
                                BorderBrush="#FF4A90D9"
                                BorderThickness="1"
                                CornerRadius="3"
                                LineStroke="#4A90D9"
                                LineThickness="1">
                <TextBlock Text="{Binding Text}"
                           Foreground="#D4D4D4"
                           FontSize="11"
                           Margin="8,4"
                           TextWrapping="NoWrap" />
            </oxy:TrackerControl>
        </ControlTemplate>

        <!-- Small icon-style button used for ✕ and + -->
        <Style x:Key="MiniButton" TargetType="Button">
            <Setter Property="Background"         Value="Transparent" />
            <Setter Property="BorderThickness"    Value="0" />
            <Setter Property="Padding"            Value="3,0" />
            <Setter Property="Cursor"             Value="Hand" />
            <Setter Property="FontSize"           Value="10" />
            <Setter Property="Foreground"         Value="#888888" />
            <Setter Property="VerticalAlignment"  Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#CCCCCC" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#1E1E1E"
            BorderBrush="#3C3C3C"
            BorderThickness="0,1,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Row 0 – Headline -->
            <TextBlock x:Name="HeadlineText"
                       Grid.Row="0"
                       Foreground="#9DA3DD"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Margin="8,4,8,2"
                       TextTrimming="CharacterEllipsis" />

            <!-- Row 1 – Control bar: series checkboxes on the left, multipliers on the right -->
            <Border x:Name="ControlBar"
                    Grid.Row="1"
                    Background="#252526"
                    BorderBrush="#3C3C3C"
                    BorderThickness="0,1,0,1"
                    Padding="6,3"
                    Visibility="Collapsed">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <DockPanel>

                        <!-- ── Multipliers (right-docked so "+" is always visible) ── -->
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <!-- Separator between series and multipliers -->
                            <Border Width="1" Background="#3C3C3C" Margin="6,1" />

                            <TextBlock Text="×"
                                       Foreground="#888888"
                                       FontSize="10"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0" />

                            <!-- One entry per multiplier -->
                            <ItemsControl x:Name="MultiplierList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#2D2D30"
                                                BorderBrush="#555555"
                                                BorderThickness="1"
                                                CornerRadius="2"
                                                Margin="0,0,4,0"
                                                Padding="2,0">
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Enable/disable this multiplier -->
                                                <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                          VerticalAlignment="Center"
                                                          Margin="1,0,2,0" />
                                                <!-- Editable value -->
                                                <TextBox Text="{Binding DisplayText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Width="52"
                                                         FontSize="10"
                                                         TextAlignment="Right"
                                                         Background="Transparent"
                                                         Foreground="#CCCCCC"
                                                         BorderThickness="0"
                                                         Padding="1,1"
                                                         VerticalAlignment="Center"
                                                         Tag="{Binding}"
                                                         KeyDown="OnMultiplierEntryKeyDown" />
                                                <!-- Remove button -->
                                                <Button Content="✕"
                                                        Style="{StaticResource MiniButton}"
                                                        Tag="{Binding}"
                                                        Click="OnRemoveMultiplierClick"
                                                        ToolTip="Remove this multiplier" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add multiplier button -->
                            <Button Content="+"
                                    Style="{StaticResource MiniButton}"
                                    FontSize="14"
                                    Padding="2,0"
                                    Click="OnAddMultiplierClick"
                                    ToolTip="Add another multiplier" />
                        </StackPanel>

                        <!-- ── Series checkboxes (fills remaining space) ── -->
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    x:Name="SeriesSection">
                            <TextBlock Text="Series  "
                                       Foreground="#888888"
                                       FontSize="10"
                                       VerticalAlignment="Center" />
                            <ItemsControl x:Name="SeriesList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  Content="{Binding Label}"
                                                  Foreground="#CCCCCC"
                                                  FontSize="10"
                                                  Margin="0,0,10,0"
                                                  VerticalAlignment="Center" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </DockPanel>
                </ScrollViewer>
            </Border>

            <!-- Row 2 – Plot -->
            <ContentControl x:Name="PlotHost"
                            Grid.Row="2"
                            MinHeight="80" />
        </Grid>
    </Border>
</UserControl>
